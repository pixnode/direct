# --- CLOB CREDENTIALS ---
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_passphrase_here

POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137

# --- PHASE 1: DATA & LOGGING ---
LOG_FILENAME=trades.csv
ORDER_EXPIRY_BUFFER=5
MAX_ORDER_RETRIES=2

# --- PHASE 2: MONITORING & ADAPTABILITY ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

GAP_VOL_NORMALIZATION=true
GAP_VOL_MULTIPLIER=1.2
VOL_ESTIMATOR_WINDOW=20

# --- PHASE 3: STRATEGY ALPHA ---
BINANCE_FEED_ENABLED=true
BINANCE_OFI_WINDOW=5.0

# --- CORE STRATEGY THRESHOLDS ---
GAP_THRESHOLD_DEFAULT=45.0
CVD_THRESHOLD_PCT=15.0
VELOCITY_MIN_DELTA=3.0
VELOCITY_WINDOW_SECONDS=2.0
DIRECTIONAL_MAX_ODDS=0.78
BASE_SHARES=1.0

# --- TIMING WINDOWS ---
CONFIRMATION_WINDOW_START=45
OVERRIDE_WINDOW_START=120
SNIPER_ZONE_END=15
OVERRIDE_GAP_THRESHOLD=110.0

# --- SYSTEM ---
HEARTBEAT_INTERVAL=1.0
VETO_MULTIPLIER=2.0
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=10
MAX_RECONNECT_DELAY=30
